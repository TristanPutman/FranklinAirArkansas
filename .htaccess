# Disable caching — always serve fresh content
<IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
</IfModule>

# Protect config file from direct access
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Protect .env file
<Files ".env">
    Order Allow,Deny
    Deny from all
</Files>

# Protect schema.sql from direct access
<Files "schema.sql">
    Order Allow,Deny
    Deny from all
</Files>

# Protect includes directory — PHP files should only be included, not accessed directly
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^includes/ - [F,L]
</IfModule>

# Protect uploads directory — files served through PHP for access control
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/ - [F,L]
</IfModule>
